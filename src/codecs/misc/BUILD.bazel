    "cd_llc.cc",
    "cd_teredo.cc",
    "cd_vxlan.cc",
    "cd_icmp4_ip.cc",
    "cd_geneve.cc",
    "cd_icmp6_ip.cc",
    "cd_user.cc",
] + glob(["*.h"], allow_empty = True),
    deps = [
    "//:src_headers",
    "//daqs:daqs_headers",
    "//src/codecs:src_codecs_headers",
    "//src/framework:src_framework_headers",
    "//src/log:src_log_headers",
    "//src/main:src_main_headers",
    "//src/packet_io:src_packet_io_headers",
